<?xml version="1.0" encoding="UTF-8"?>
<!--
  OBJECT TEMPLATE — Secure-CCL
  Asigna roles automáticamente según el atributo 'ou' del usuario.

  Mapeo:
    ou=direccion  -> role_admin + role_manager
    ou=tecnologia -> role_employee + role_manager
    ou=ventas     -> role_employee
    ou=recursos   -> role_employee
    ou=finanzas   -> role_employee

  Cómo importarlo:
  1. MidPoint -> Import object -> selecciona este fichero -> Import object
  2. Ve a Configuration -> Object policies
  3. Añade una policy para UserType que use este template
-->
<objectTemplate xmlns="http://midpoint.evolveum.com/xml/ns/public/common/common-3"
                xmlns:q="http://prism.evolveum.com/xml/ns/public/query-3"
                xmlns:org="http://midpoint.evolveum.com/xml/ns/public/common/org-3"
                oid="10000000-0000-0000-0000-000000000001">

    <name>Secure-CCL User Template</name>
    <description>Asigna roles automáticamente según el departamento (ou) del usuario LDAP.</description>

    <!-- ── DIRECCIÓN: role_admin + role_manager ─────────────────────────── -->
    <mapping>
        <name>assign-role-admin-to-direccion</name>
        <strength>strong</strength>
        <source>
            <path>organizationalUnit</path>
        </source>
        <condition>
            <script>
                <code>
                    def ou = basic.stringify(organizationalUnit)
                    return ou == 'direccion'
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="aa6bd7d8-b55e-4db4-9a3f-396cbc23e648" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

    <mapping>
        <name>assign-role-manager-to-direccion</name>
        <strength>strong</strength>
        <source>
            <path>organizationalUnit</path>
        </source>
        <condition>
            <script>
                <code>
                    def ou = basic.stringify(organizationalUnit)
                    return ou == 'direccion'
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="b9bc79f2-1a26-4bbe-b274-2fb572e4eeea" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

    <mapping>
        <name>assign-role-manager-to-tecnologia</name>
        <strength>strong</strength>
        <source>
            <path>organizationalUnit</path>
        </source>
        <condition>
            <script>
                <code>
                    def ou = basic.stringify(organizationalUnit)
                    return ou == 'tecnologia'
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="b9bc79f2-1a26-4bbe-b274-2fb572e4eeea" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

    <mapping>
        <name>assign-role-employee-to-tecnologia</name>
        <strength>strong</strength>
        <source>
            <path>organizationalUnit</path>
        </source>
        <condition>
            <script>
                <code>
                    def ou = basic.stringify(organizationalUnit)
                    return ou == 'tecnologia'
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="a01b7f89-0043-472d-b259-4f1c9a7365b3" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

    <mapping>
        <name>assign-role-employee-to-others</name>
        <strength>strong</strength>
        <source>
            <path>organizationalUnit</path>
        </source>
        <condition>
            <script>
                <code>
                    def ou = basic.stringify(organizationalUnit)
                    return ou in ['ventas', 'recursos', 'finanzas']
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="a01b7f89-0043-472d-b259-4f1c9a7365b3" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

    <!-- ── ACCESS REQUEST: role_manager por solicitud aprobada ─────────────── -->
    <mapping>
        <name>assign-role-manager-by-request</name>
        <strength>strong</strength>
        <source>
            <path>title</path>
        </source>
        <condition>
            <script>
                <code>
                    def empType = basic.stringify(description)
                    return empType == 'role_manager'
                </code>
            </script>
        </condition>
        <target>
            <path>assignment</path>
        </target>
        <expression>
            <value>
                <targetRef oid="b9bc79f2-1a26-4bbe-b274-2fb572e4eeea" type="RoleType" relation="org:default"/>
            </value>
        </expression>
    </mapping>

</objectTemplate>
