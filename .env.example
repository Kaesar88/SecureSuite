# Copia este fichero como .env y rellena los valores
# cp .env.example .env

# Contraseña del administrador de OpenLDAP (cn=admin)
LDAP_ADMIN_PASSWORD=changeme

# Contraseña del administrador de Keycloak
KEYCLOAK_ADMIN_PASSWORD=changeme

# MidPoint (IGA)
MIDPOINT_DB_PASSWORD=changeme
MIDPOINT_ADMIN_PASSWORD=changeme

LDAP_SERVICE_API_KEY=changeme
